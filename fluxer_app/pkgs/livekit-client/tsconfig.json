{
	"compilerOptions": {
		"target": "ES2015",
		"module": "ES2020",
		"lib": [
			"DOM",
			"DOM.Iterable",
			"DOM.AsyncIterable",
			"ES2017",
			"ES2018.Promise",
			"ES2020",
			"ES2021.WeakRef",
			"ES2022.Error"
		],
		"rootDir": "./",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"verbatimModuleSyntax": false,
		"allowImportingTsExtensions": true,
		"noEmit": true
	},
	"exclude": ["dist"],
	"include": ["src/**/*.ts", "src/**/*.d.ts"]
}
