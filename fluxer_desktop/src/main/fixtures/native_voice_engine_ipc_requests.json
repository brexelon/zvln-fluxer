{
	"version": 1,
	"name": "native_voice_engine_ipc_requests",
	"cases": [
		{
			"name": "valid connect reaches the native engine",
			"channel": "connect",
			"event": "sender",
			"args": [{"url": "wss://voice.example.test", "token": "token-connect"}],
			"expected": {"result": "void", "engineCalls": {"connect": 1}}
		},
		{
			"name": "invalid connect args throw",
			"channel": "connect",
			"event": "sender",
			"args": [{"url": "wss://voice.example.test", "token": ""}],
			"expected": {"throws": "Invalid voice-engine connect args"}
		},
		{
			"name": "invalid mic enabled args return typed operation failure",
			"channel": "setMicEnabled",
			"args": ["yes"],
			"expected": {
				"result": {
					"ok": false,
					"error": {
						"code": "invalid-args",
						"message": "Invalid voice-engine set-mic-enabled args"
					}
				}
			}
		},
		{
			"name": "valid microphone publish returns typed success",
			"setup": "connected",
			"channel": "publishMicrophone",
			"args": [{"mode": "pcm-test", "sampleRate": 48000, "numChannels": 2}],
			"expected": {"result": {"ok": true}}
		},
		{
			"name": "invalid microphone publish returns typed operation failure",
			"channel": "publishMicrophone",
			"args": [{"mode": "pcm-test", "sampleRate": "48000", "numChannels": 2}],
			"expected": {
				"result": {
					"ok": false,
					"error": {
						"code": "invalid-args",
						"message": "Invalid voice-engine publish-microphone args",
						"capability": "microphoneCapture"
					}
				}
			}
		},
		{
			"name": "valid zero-copy screen publish reaches native engine",
			"setup": "connected",
			"channel": "publishScreen",
			"args": [
				{
					"captureId": "capture-zero-copy",
					"width": 1920,
					"height": 1080,
					"codec": "h264",
					"maxBitrateBps": 6000000,
					"maxFramerate": 60,
					"hardwareEncoding": true,
					"zeroCopyRequired": true
				}
			],
			"expected": {"result": "void", "engineCalls": {"publishScreenShare": 1}}
		},
		{
			"name": "explicit non-zero-copy screen publish is rejected",
			"setup": "connected",
			"channel": "publishScreen",
			"args": [
				{
					"captureId": "capture-copying",
					"width": 1920,
					"height": 1080,
					"zeroCopyRequired": false
				}
			],
			"expected": {"throws": "requires zero-copy transport"}
		},
		{
			"name": "hardware screen encoding without zero-copy is rejected",
			"setup": "screen",
			"channel": "updateScreenShareEncoding",
			"args": [
				{
					"captureId": "fixture-screen",
					"width": 1280,
					"height": 720,
					"hardwareEncoding": true,
					"zeroCopyRequired": false
				}
			],
			"expected": {"throws": "requires zero-copy transport"}
		},
		{
			"name": "valid native screen audio publish reaches native engine",
			"setup": "connected",
			"channel": "publishScreenAudio",
			"args": [{"sampleRate": 48000, "numChannels": 2, "route": "native", "captureId": "capture-zero-copy"}],
			"expected": {"result": "void", "engineCalls": {"publishScreenShareAudio": 1}}
		},
		{
			"name": "invalid screen audio route throws",
			"setup": "connected",
			"channel": "publishScreenAudio",
			"args": [{"sampleRate": 48000, "numChannels": 2, "route": "loopback"}],
			"expected": {"throws": "Invalid voice-engine publish-screen-audio args"}
		},
		{
			"name": "valid camera publish reaches native engine",
			"setup": "connected",
			"channel": "publishCamera",
			"args": [{"deviceId": "camera-1", "width": 1280, "height": 720, "frameRate": 30}],
			"expected": {"result": "void", "engineCalls": {"publishCamera": 1}}
		},
		{
			"name": "valid native camera sink publish reaches native engine",
			"setup": "connected",
			"channel": "publishNativeCameraSink",
			"args": [{"deviceId": "camera-1", "width": 1280, "height": 720, "frameRate": 30, "backgroundMode": "blur"}],
			"expected": {"result": {"trackSid": "TR_native_camera"}, "engineCalls": {"publishNativeCameraSink": 1}}
		},
		{
			"name": "valid processed camera publish reaches native engine",
			"setup": "connected",
			"channel": "publishProcessedCamera",
			"args": [{"width": 1280, "height": 720, "frameRate": 30}],
			"expected": {"result": {"trackSid": "TR_processed_camera"}, "engineCalls": {"publishProcessedCamera": 1}}
		},
		{
			"name": "valid processed camera frame reaches native engine",
			"setup": "connected",
			"channel": "pushProcessedCameraFrame",
			"args": [
				{"format": "i420", "width": 2, "height": 2, "timestampUs": 1, "data": {"$arrayBuffer": [1, 1, 1, 1, 2, 3]}}
			],
			"expected": {"result": true, "engineCalls": {"processedCameraFrames": 1}}
		},
		{
			"name": "invalid processed camera frame throws",
			"setup": "connected",
			"channel": "pushProcessedCameraFrame",
			"args": [{"format": "i420", "width": 2, "height": 2, "timestampUs": 1, "data": {"$arrayBuffer": [1, 2, 3]}}],
			"expected": {"throws": "Invalid voice-engine push-processed-camera-frame args"}
		},
		{
			"name": "invalid camera publish throws",
			"setup": "connected",
			"channel": "publishCamera",
			"args": [{"deviceId": "camera-1", "frameRate": 0}],
			"expected": {"throws": "Invalid voice-engine publish-camera args"}
		},
		{
			"name": "connected stats return normalized empty stats",
			"setup": "connected",
			"channel": "getConnectionStats",
			"args": [],
			"expected": {"result": {"rttMs": null, "outbound": [], "inbound": []}}
		},
		{
			"name": "valid participant volume reaches native engine",
			"setup": "connected",
			"channel": "setParticipantVolume",
			"args": [{"participantSid": "participant-1", "volume": 0.75}],
			"expected": {"result": "void", "engineCalls": {"setParticipantVolume": 1}}
		},
		{
			"name": "invalid participant volume throws",
			"setup": "connected",
			"channel": "setParticipantVolume",
			"args": [{"participantSid": "", "volume": 0.75}],
			"expected": {"throws": "Invalid voice-engine set-participant-volume args"}
		},
		{
			"name": "valid remote subscription reaches native engine",
			"setup": "connected",
			"channel": "setRemoteTrackSubscription",
			"args": [{"participantIdentity": "alice", "source": "screen", "subscribed": true, "quality": "high"}],
			"expected": {"result": "void", "engineCalls": {"remoteTrackSubscription": 1}}
		},
		{
			"name": "invalid remote subscription quality throws",
			"setup": "connected",
			"channel": "setRemoteTrackSubscription",
			"args": [{"participantIdentity": "alice", "source": "screen", "subscribed": true, "quality": "ultra"}],
			"expected": {"throws": "Invalid voice-engine set-remote-track-subscription args"}
		},
		{
			"name": "valid data publish reaches native engine",
			"setup": "connected",
			"channel": "publishData",
			"args": [{"payload": {"$arrayBuffer": [1, 2, 3, 4]}, "reliable": true, "topic": "fixture"}],
			"expected": {"result": "void", "engineCalls": {"publishData": 1}}
		},
		{
			"name": "invalid data payload throws",
			"setup": "connected",
			"channel": "publishData",
			"args": [{"payload": [1, 2, 3, 4], "reliable": true}],
			"expected": {"throws": "Invalid voice-engine publish-data args"}
		}
	]
}
